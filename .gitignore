frontend/build/
frontend/.cache/
.npm/
.yarn/cache/
.yarn/unplugged/
.yarn/install-state.gz
.pnp.*
package-lock.json

# ── Rust / Tauri ──────────────────────────────────────────────────────────────
desktop/src-tauri/target/
desktop/node_modules/
t/

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Lokale Datei-Uploads (kein Code, nur Laufzeit-Daten) ─────────────────────
backend/storage/uploads/
backend/storage/minio-data/

# ── Betriebssystem ────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDEs & Editoren ───────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.swp
*.swo
*~
.project
.classpath

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

