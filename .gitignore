# .gitignore – Singra Vox

# ── Geheimnisse & Konfiguration ──────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx

# ── Agent- & Plattform-interne Dateien (nicht für Repo) ──────────────────────
memory/
.emergent/
test_reports/
_archive/
*.emergent

# ── KI-Assistenten (Cursor, Claude Code, Codex, Aider usw.) ──────────────────
.cursor/
.claude/
CLAUDE.md
.aider*
.codex/
codex.md
.copilot/
.github/copilot*
*.agent.md
AGENTS.md

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.pytest_cache/
