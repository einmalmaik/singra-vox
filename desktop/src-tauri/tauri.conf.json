{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/tauri-v2/crates/tauri-cli/schema.json",
  "productName": "Singra Vox",
  "version": "0.1.0",
  "identifier": "com.singravox.desktop",
  "build": {
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "beforeDevCommand": "npm --prefix ../frontend run start",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../frontend/build"
  },
  "app": {
    "windows": [
      {
        "title": "Singra Vox",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"]
      }
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["singravox"]
      }
    }
  }
}
