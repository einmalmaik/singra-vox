# ══════════════════════════════════════════════════════════════════════════════
# Singra Vox – Backend Konfiguration (.env)
# ══════════════════════════════════════════════════════════════════════════════
#
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
#
# PFLICHT-Variablen sind mit [PFLICHT] markiert.
# Generiere Secrets mit: python3 -c "import secrets;print(secrets.token_hex(32))"
#
# ── Datenbank ────────────────────────────────────────────────────────────────

# [PFLICHT] MongoDB-Verbindungs-URL
MONGO_URL=mongodb://localhost:27017

# [PFLICHT] Name der Datenbank
DB_NAME=singravox

# ── Sicherheit ───────────────────────────────────────────────────────────────

# [PFLICHT] Geheimnis für JWT-Tokens (min. 32 Zeichen, einmal generieren!)
JWT_SECRET=

# [PFLICHT] Verschlüsselungsschlüssel für ALLE Daten (Nachrichten, Dateien, Metadaten)
# WARNUNG: Einmal gesetzt, NIEMALS ändern! Alle Daten werden sonst unlesbar!
# Generieren: python3 -c "import secrets;print(secrets.token_hex(32))"
INSTANCE_ENCRYPTION_SECRET=

# Secure-Flag für Auth-Cookies (true für HTTPS, false für lokale Entwicklung)
COOKIE_SECURE=false

# ── Frontend ─────────────────────────────────────────────────────────────────

# [PFLICHT] Öffentliche URL des Frontends (für CORS und E-Mail-Links)
FRONTEND_URL=http://localhost:3000

# ── Singra Vox ID (Identity Server) ─────────────────────────────────────────

# Öffentliche URL dieser Instanz (für OAuth2 Issuer-Feld)
# Setzen wenn du Singra Vox ID nutzen willst
SVID_ISSUER=https://voxid.mauntingstudios.de

# JWT-Geheimnis für SVID-Tokens (eigenes Secret, nicht das gleiche wie JWT_SECRET!)
SVID_JWT_SECRET=

# ── LiveKit (Voice/Video) ───────────────────────────────────────────────────

# LiveKit-Server WebSocket-URL (wss:// für Cloud, ws:// für lokal)
LIVEKIT_URL=

# LiveKit API-Credentials (aus dem LiveKit Dashboard)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── E-Mail (SMTP) ───────────────────────────────────────────────────────────
#
# Wird benötigt für: E-Mail-Verifizierung, Passwort-Reset, Einladungen
# Ohne SMTP werden neue Nutzer automatisch verifiziert (nur für Entwicklung!)
#
# Beispiel für Resend.com:
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USERNAME=resend
#   SMTP_PASSWORD=re_xxxxxxxx
#   SMTP_FROM_EMAIL=noreply@deine-domain.de
#   SMTP_USE_SSL=true

SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Singra Vox
SMTP_USE_SSL=true
SMTP_USE_TLS=false

# ── Blob-Speicher (S3, optional) ────────────────────────────────────────────
#
# Für client-seitig verschlüsselte Datei-Anhänge (E2EE-Blobs)
# Standard: lokaler Dateispeicher unter storage/uploads/

# S3_ENDPOINT_URL=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=singravox-e2ee
# S3_REGION=eu-central-1
