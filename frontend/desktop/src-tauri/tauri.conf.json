{
  "$schema": "https://raw.githubusercontent.com/nicehash/Tauri/v2/crates/tauri-cli/schema.json",
  "productName": "Singra Vox",
  "version": "0.1.0",
  "identifier": "com.singravox.app",
  "build": {
    "beforeBuildCommand": "yarn build",
    "beforeDevCommand": "yarn start",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../build"
  },
  "app": {
    "windows": [
      {
        "title": "Singra Vox",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": { "depends": [] },
      "appimage": { "bundleMediaFramework": true }
    }
  }
}
