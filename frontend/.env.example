# ══════════════════════════════════════════════════════════════════════════════
# Singra Vox – Frontend Konfiguration (.env)
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and adjust:
#   cp .env.example .env
#
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
#
# ── API URL ──────────────────────────────────────────────────────────────────
#
# [REQUIRED / PFLICHT]
# The public URL of your Singra Vox instance (without trailing slash).
# Die öffentliche URL deiner Singra-Vox-Instanz (ohne abschließenden /).
#
# In production with a reverse proxy (Caddy/nginx), set this to the
# same domain. The frontend uses window.location.origin at runtime,
# so this is mainly used during the build step (Create React App).
#
# Beispiele / Examples:
#   REACT_APP_BACKEND_URL=https://chat.example.com
#   REACT_APP_BACKEND_URL=http://192.168.1.50:8080
#
REACT_APP_BACKEND_URL=http://localhost:8080
